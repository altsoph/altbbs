# Copy to .env and fill in. NEVER commit .env.
# Get a token from @BotFather in Telegram.
BBS_BOT_TOKEN=123456:ABC-DEF...

# Cosmetics / policy (all optional)
BBS_NAME=altBBS
BBS_TAGLINE=est. 2026 * 34 cols * node 1
# open = anyone may register, closed = sysop must /invite <tg_user_id>
BBS_NEW_USERS=open

# news wire: scheduled import from HN / lobste.rs / shir-man.com
# into the "hn wire" / "lobsters wire" / "trends wire" boards
BBS_FEED=on
BBS_FEED_INTERVAL_MIN=180
BBS_FEED_MAX_PER_SOURCE=5
BBS_FEED_HN_MIN_SCORE=100
# custom RSS/Atom feeds: path to an OPML file (e.g. a feedly export).
# empty = auto-use the first *.opml found in the repo root.
BBS_FEED_OPML=
# skip OPML feed entries older than this many days
BBS_FEED_MAX_AGE_DAYS=45
